# Qualia Core Environment Variables
# Copy this file to .env and configure your values

# Transcription (Groq Whisper API)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Logging
LOG_LEVEL=INFO

# CORS (default: * aceita qualquer origem)
# Em produção, restringir: CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5173
# CORS_ALLOWED_ORIGINS=*

# Webhook Secrets (used by docker-compose.yml, optional)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# GITHUB_WEBHOOK_SECRET=your_secret_here
# SLACK_SIGNING_SECRET=your_secret_here
